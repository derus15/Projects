print('Добро пожаловать в Калькулятор')
while True:

    import time

    time.sleep(1)
    print('Пожалуйста, выберите операцию:', '1.Умножение', '2.Сложение', '3.Вычитание', '4.Деление', sep='\n')
    s = int(input())
    if s == 1:
        k = 'умножить'
    elif s == 2:
        k = 'сложить'
    elif s == 3:
        k = 'вычесть'
    elif s == 4:
        k = 'поделить'
    else:
        print('некорректные данные')
        qw = input("Нажмите любую клавишу, чтобы начать заново или 'нет', если хотите закрыть программу ")
        if qw == 'нет':
            break
    print('Введите числа, которые хотите', k + '.', '\n' +
          'Каждое число вводите на отдельной строке. Дробные числа записываются с помощью точки')
    a = float(input())
    b = float(input())
    if s == 1:
        print('Ответ:', a * b)
    elif s == 2:
        print('Ответ:', a + b)
    elif s == 3:
        print('Ответ:', a - b)
    elif s == 4 and b == 0:
        print('Делить на ноль нельзя')
        break
    elif s == 4:
        print('Ответ:', a / b)
    qw = input("Нажмите любую клавишу, чтобы начать заново или 'нет', если хотите закрыть программу ")
    if qw == 'нет':
        break
